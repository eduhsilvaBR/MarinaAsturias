ADMIN_PASSWORD=troque-esta-senha
ADMIN_SESSION_SECRET=gere-um-valor-aleatorio-longo

# Opcionais: só necessários em produção (Vercel). Sem eles, o admin usa
# disco local automaticamente (bom para desenvolvimento).
#
# Vercel → Storage → Create Database → Blob → Connect ao projeto
# (preenche BLOB_READ_WRITE_TOKEN sozinho)
# BLOB_READ_WRITE_TOKEN=
#
# Vercel → Storage → Create Database → Upstash for Redis → Connect ao projeto
# (preenche essas duas sozinho)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
